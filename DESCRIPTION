Package: heuristR
Title: R Client for Heurist Databases
Version: 0.0.0.9000
Authors@R: c(
    person(
      given = "Robert J.",
      family = "Bischoff",
      email = "rbischoff@asu.edu",
      role = c("aut", "cre")
